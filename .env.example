# Production Environment Variables
# Copy this file to .env and fill in your actual values

# Required
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://propertydamagesupport.com

# Google Analytics (replace with your actual tracking ID)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=support@cbrsgroup.com
NEXT_PUBLIC_PHONE=(832) 608-0535

# Google Search Console Verification (replace with actual code)
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code-here

# Optional: API Keys
# Add any API keys or secret keys here
# Never commit .env to version control
